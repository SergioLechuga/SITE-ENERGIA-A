# ═══════════════════════════════════════════════════════════════════
# ENERGIA A — Variáveis de Ambiente
# Copie este arquivo para ".env" e preencha com seus dados reais.
# NUNCA envie o arquivo ".env" para o GitHub (já está no .gitignore).
# Configure essas variáveis no painel do Vercel em:
# Settings > Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── GOOGLE SHEETS API ─────────────────────────────────────────────
# E-mail da Service Account (ex: energia-a@seu-projeto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=sua-service-account@seu-projeto.iam.gserviceaccount.com

# Chave privada da Service Account (cole o conteúdo completo entre aspas)
# Exemplo: "-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ID da planilha Google Sheets (está na URL: docs.google.com/spreadsheets/d/ID_AQUI/edit)
GOOGLE_SHEET_ID=1A2B3C4D5E6F7G8H9I0J_exemplo

# ── E-MAIL (NOTIFICAÇÃO AO CLOSER) ───────────────────────────────
# Conta Gmail que vai ENVIAR as notificações (use uma conta dedicada)
SMTP_USER=seuemail@gmail.com

# Senha de App do Gmail (NÃO a senha normal da conta)
# Gere em: myaccount.google.com > Segurança > Senhas de app
SMTP_PASS=abcd efgh ijkl mnop

# E-mail que receberá as notificações de novos leads (responsável comercial)
NOTIFY_EMAIL=comercial@energiaa.com.br

# E-mail do Closer (pode ser o mesmo de NOTIFY_EMAIL)
CLOSER_EMAIL=closer@energiaa.com.br

# ── WEBHOOK FUTURO (opcional) ─────────────────────────────────────
# URL de webhook para n8n, Make, RD Station, HubSpot etc.
# Descomente no api/leads.js quando for usar
# WEBHOOK_URL=https://sua-automacao.com/webhook/leads

# ── CALLMEBOT WHATSAPP (opcional) ────────────────────────────────
# Registre em: callmebot.com/blog/free-api-whatsapp-messages/
# CALLMEBOT_PHONE=5567999238972
# CALLMEBOT_APIKEY=sua_apikey_aqui
